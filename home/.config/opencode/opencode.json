{
  "$schema": "https://opencode.ai/config.json",
  "references": {
    "vault": {
      "path": "~/Code/agent-vault/",
      "description": "obsidian vault that act as durable memory for the user and AI agents"
    }
  },
  "permission": {
    "external_directory": {
      "~/Code/agent-vault/**": "allow"
    },
    "edit": {
      "~/Code/agent-vault/**": "allow"
    }
  },
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-8": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "max"
          }
        },
        "claude-opus-4-7": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            },
            "effort": "max"
          }
        },
        "claude-opus-4-5": {
          "headers": {
            "anthropic-beta": "context-1m-2025-08-07"
          },
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "options": {
            "effort": "high"
          }
        }
      }
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.5-fast": {
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.5-pro": {
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        }
      }
    }
  }
}
