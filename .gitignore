.DS_Store
backups/

# OpenCode generated content
home/.config/opencode/.git/
home/.config/opencode/node_modules/
home/.config/opencode/state/

# OpenCode local runtime output
.opencode/plans/

# Local tmux plugins managed by TPM
home/.config/tmux/plugins/

# Local-only overrides (never commit)
home/.gitconfig.local
home/.zshrc.local
home/.zshenv.local
home/.zprofile.local

# Credential / secret stores
home/.netrc
home/.ssh/
home/.gnupg/
home/.aws/
home/.docker/
home/.kube/
home/.config/gh/
home/.config/op/
home/.config/1Password/

# Env files anywhere under home/
home/**/.env
home/**/.env.*
home/**/*.env

# Common token / key file shapes
home/**/*.pem
home/**/*.key
home/**/id_rsa*
home/**/id_ed25519*
home/**/*.token
