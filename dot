#!/usr/bin/env bash

set -euo pipefail

export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:${PATH}"

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOME_DIR="${DOTFILES_DIR}/home"
PACKAGES_DIR="${DOTFILES_DIR}/packages"

say() {
  printf '%s\n' "$1"
}

fail() {
  printf 'error: %s\n' "$1" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "missing command: $1"
}

install_packages() {
  need_cmd brew
  brew bundle --file="${PACKAGES_DIR}/bundle"
}

install_oh_my_zsh() {
  local omz_dir="${HOME}/.oh-my-zsh"

  if [[ -d "${omz_dir}/.git" ]]; then
    say "ok: oh-my-zsh"
    return 0
  fi

  if [[ -e "${omz_dir}" ]]; then
    fail "~/.oh-my-zsh exists but is not a git checkout"
  fi

  need_cmd git
  say "installing: oh-my-zsh"
  git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git "${omz_dir}"
}

restow() {
  need_cmd stow
  stow -R -d "${DOTFILES_DIR}" -t "${HOME}" home
}

doctor() {
  local missing=0
  local commands=(bat brew fd fnm fzf git stow yazi zoxide zsh)

  for cmd in "${commands[@]}"; do
    if command -v "$cmd" >/dev/null 2>&1; then
      say "ok: $cmd"
    else
      say "missing: $cmd"
      missing=1
    fi
  done

  if [[ -d "${HOME}/.oh-my-zsh/.git" ]]; then
    say "ok: oh-my-zsh"
  else
    say "missing: oh-my-zsh"
    missing=1
  fi

  if stow -n -R -d "${DOTFILES_DIR}" -t "${HOME}" home >/dev/null; then
    say "ok: stow dry-run"
  else
    say "warning: stow dry-run reported conflicts"
    missing=1
  fi

  return "$missing"
}

usage() {
  cat <<'EOF'
Usage: ./dot <command>

Commands:
  init    install bundle, oh-my-zsh, and stow files
  stow    restow managed files into $HOME
  doctor  check core commands and stow health
EOF
}

main() {
  local command="${1:-help}"

  case "$command" in
    init)
      install_packages
      install_oh_my_zsh
      restow
      ;;
    stow)
      restow
      ;;
    doctor)
      doctor
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
